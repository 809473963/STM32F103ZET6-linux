<?xml version="1.0"?>
<robot name="wheeltec_chassis">
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.09" rpy="0 0 0"/>
      <geometry>
        <box size="0.36 0.28 0.18"/>
      </geometry>
      <material name="chassis_blue">
        <color rgba="0.1 0.4 0.9 1.0"/>
      </material>
    </visual>
  </link>

  <link name="left_track">
    <visual>
      <origin xyz="0 0.17 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.34 0.06 0.10"/>
      </geometry>
      <material name="track_black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
  </link>

  <link name="right_track">
    <visual>
      <origin xyz="0 -0.17 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.34 0.06 0.10"/>
      </geometry>
      <material name="track_black"/>
    </visual>
  </link>

  <joint name="left_track_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_track"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="right_track_joint" type="fixed">
    <parent link="base_link"/>
    <child link="right_track"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
</robot>
